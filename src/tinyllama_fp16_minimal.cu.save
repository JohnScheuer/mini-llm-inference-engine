using json = nlohmann::json;

#define CUDA_CHECK(x) \
do { \
    cudaError_t err = (x); \
    if (err != cudaSuccess) { \
        printf("CUDA error: %s at %s:%d\n", \
               cudaGetErrorString(err), \
               __FILE__, __LINE__); \
        exit(1); \
    } \
} while(0)

////////////////////////////////////////////////////////////////
// SIMPLE FP16 GEMM USING CUBLAS
////////////////////////////////////////////////////////////////

void gemm_fp16(
    cublasHandle_t handle,
    int m, int n, int k,
    const half* A,
    const half* B,
    half* C)
{
    float al                 CUBLAS_OP_N,
                 m, n, k,
                 &alpha,
                 A, CUDA_R_16F, m,
                 B, CUDA_R_16F, k,
                 &beta,
                 C, CUDA_R_16F, m,
                 CUBLAS_COMPUTE_32F,
                 CUBLAS_GEMM_DEFAULT);
}

////////////////////////////////////////////////////////////////
// RMSNORM
////////////////////////////////////////////////////////////////

__global__ void rmsnorm_kernel(
    half* out,
    const half* x,
    const half* gamma,
    int dim,
    float eps)
{
    __shared__ float sdata[256];

    int tid = threadIdx.x;
    float local = 0.f;

    for (int i = tid; i < dim; i += blockDim.x) {
        float v = __half2float(x[i]);
        local += v * v;
    }

    sdata[tid] = local;
    __syncthreads();

    for (int s = blockDim.x/2; s > 0; s >>= 1) {
        if (tid < s)
            sdata[tid] += sdata[tid + s];
        __syncthreads();
    }

    float rms = rsqrtf(sdata[0] / dim + eps);

    for (int i = tid; i < dim; i += blockDim.x) {
        float v = __half2float(x[i]);
        float g = __half2float(gamma[i]);
        out[i] = __float2half(v * rms * g);
    }
}

////////////////////////////////////////////////////////////////
// MAIN
////////////////////////////////////////////////////////////////

int main(int argc, char** argv)
{
    if (argc < 4) {
        std::cout << "Usage: ./tinyllama_fp16_minimal model.safetensors tokenizer.json \"prompt\"\n";
        return 0;
    }

    std::string model_path = argv[1];
    std::string tokenizer_path = argv[2];
    std::string prompt = argv[3];

    Tokenizer tokenizer;
    tokenizer.load(tokenizer_path);

    Model m;
    m.dim = 2048;
    m.hidden_dim = 5632;
    m.n_layers = 22;
    m.n_heads = 32;
    m.vocab_size = 32000;
    m.max_seq_len = 2048;
    m.layers.resize(m.n_layers);

    std::cout << "[Loader] Loading weights...\n";
    load_safetensors_improved(model_path, m);

    cublasHandle_t handle;
    cublasCreate(&handle);

    std::vector<int> ids = tokenizer.encode(prompt);
    ids.insert(ids.begin(), 1);

    int token = ids[ids.size()-1];

    half* d_qkv;
    CUDA_CHECK(cudaMalloc(&d_qkv, 3 * m.dim * sizeof(half)));

    // Converter weight para half
    std::vector<half> h_wqkv(3 * m.dim * m.dim);

    for(int i = 0; i < m.dim * m.dim; i++)
        h_wqkv[i] = __float2half(layer.wq.data[i]);

    for(int i = 0; i < m.dim * m.dim; i++)
        h_wqkv[m.dim*m.dim + i] = __float2half(layer.wk.data[i]);

    for(int i = 0; i < m.dim * m.dim; i++)
        h_wqkv[2*m.dim*m.dim + i] = __float2half(layer.wv.data[i]);

    half* d_wqkv;
    CUDA_CHECK(cudaMalloc(&d_wqkv, 3 * m.dim * m.dim * sizeof(half)));
    CUDA_CHECK(cudaMemcpy(d_wqkv, h_wqkv.data(),
                          3*m.dim*m.dim*sizeof(half),
                          cudaMemcpyHostToDevice));

    gemm_fp16(handle,
              3*m.dim,   // m
              1,         // n (1 token)
              m.dim,     // k
              d_wqkv,
              d_norm,
              d_qkv);

    CUDA_CHECK(cudaDeviceSynchronize());

    // ===== Copy back first few values =====

    std::vector<half> h_qkv(3 * m.dim);
    CUDA_CHECK(cudaMemcpy(h_qkv.data(),
                          d_qkv,
                          3*m.dim*sizeof(half),
                          cudaMemcpyDeviceToHost));

    std::cout << "\n[DEBUG] First 5 Q values:\n";
    for(int i=0;i<5;i++)
        std::cout << __half2float(h_qkv[i]) << " ";
    std::cout << "\n";

    std::cout << "\n[DEBUG] First 5 K values:\n";
    for(int i=0;i<5;i++)
        std::cout << __half2float(h_qkv[m.dim + i]) << " ";
    std::cout << "\n";

    std::cout << "\n[DEBUG] First 5 V values:\n";
    for(int i=0;i<5;i++)
        std::cout << __half2float(h_qkv[2*m.dim + i]) << " ";
    std::cout << "\n";

    std::cout << "[Done] QKV computed.\n";

    return 0;
